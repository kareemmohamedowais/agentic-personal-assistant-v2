# ─── Server Configuration ────────────────────────────────────
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ─── LLM Providers ──────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key
# GOOGLE_API_KEY_2=your_second_key
# GOOGLE_API_KEY_3=your_third_key

GROQ_API_KEY=your_groq_api_key

# OpenRouter (optional — 100+ models)
OPENROUTER_API_KEY=your_openrouter_key

# ─── Vector DB (Pinecone) ───────────────────────────────────
PINECONE_API_KEY=pcsk_zzzzz
PINECONE_INDEX=agentic-rag-index

# ─── JWT (REQUIRED — server will not start without this) ────
JWT_SECRET=

# ─── Web Search (optional) ──────────────────────────────────
TAVILY_API_KEY=tvly_zzzzz

# ─── LangSmith Observability (optional) ─────────────────────
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_zzzzz
LANGSMITH_PROJECT="Agentic RAG"